{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "reactnativecesium"
  ],
  "ios": {
    "iosModuleName": "ReactNativeCesium"
  },
  "android": {
    "androidNamespace": [
      "reactnativecesium"
    ],
    "androidCxxLibName": "ReactNativeCesium"
  },
  "autolinking": {
    "CesiumView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridCesiumView"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridCesiumView"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
