{
  "name": "react-native-cesium",
  "version": "1.0.1",
  "description": "Experimental Cesium rendering for React Native via Nitro (iOS/Metal today; Android planned)",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "src/index",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node scripts/cesium/clean.mjs",
    "release": "semantic-release --no-ci --repository-url \"git@github.com:dpyeates/react-native-cesium.git\"",
    "release:dry": "semantic-release --dry-run --no-ci --repository-url \"git@github.com:dpyeates/react-native-cesium.git\"",
    "build": "node scripts/cesium/build.mjs",
    "build:js": "npm run typecheck && bob build",
    "update": "node scripts/cesium/clone.mjs",
    "ensure-native": "node scripts/cesium/ensure-native.mjs",
    "cesium:update": "npm run update",
    "codegen": "nitrogen --logLevel=\"debug\" && npm run build:js && node post-script.js",
    "prepublishOnly": "npm run build:js"
  },
  "keywords": [
    "react-native",
    "react-native-cesium",
    "nitro-modules",
    "cesium",
    "metal",
    "vulkan"
  ],
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "LICENSE",
    "NOTICE",
    "nitrogen",
    "scripts/cesium",
    "cpp",
    "nitro.json",
    "android/build.gradle",
    "android/fix-prefab.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src",
    "example/react-native-cesium-example.jpg",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.rb",
    "ios/**/*.swift",
    "*.podspec",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dpyeates/react-native-cesium.git"
  },
  "author": "Darren Yeates",
  "license": "MIT",
  "bugs": "https://github.com/dpyeates/react-native-cesium/issues",
  "homepage": "https://github.com/dpyeates/react-native-cesium#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "react-native-nitro-modules": "^0.35.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@jamesacarr/eslint-formatter-github-actions": "^0.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "19.2.14",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "nitrogen": "0.35.4",
    "react": "19.2.3",
    "react-native": "0.85.1",
    "react-native-builder-bob": "^0.41.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
